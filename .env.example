# PostgreSQL Configuration
POSTGRES_DB=cypherguard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cypherguard-kb
MINIO_SECURE=false

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333

# JWT Configuration
JWT_SECRET=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Model Gateway Configuration
MODEL_GATEWAY_URL=http://model-gateway:8000

# Upload Limits
UPLOAD_MAX_MB=100
URL_FETCH_MAX_MB=50
URL_FETCH_TIMEOUT_SECONDS=30

# SSRF Protection (optional)
# SSRF_ALLOWLIST=
# SSRF_BLOCKLIST=127.0.0.1,localhost,169.254.169.254

# Timeouts
REQUEST_TIMEOUT_SECONDS=300
EMBEDDING_TIMEOUT_SECONDS=60
CHAT_TIMEOUT_SECONDS=120
RERANK_TIMEOUT_SECONDS=30

# Default Model Configurations (can be overridden in database)
# DEFAULT_CHAT_MODEL=gpt-3.5-turbo
# DEFAULT_EMBEDDING_MODEL=text-embedding-ada-002
# DEFAULT_RERANK_MODEL=

# OpenAI API Configuration (example)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama Configuration (example)
# OLLAMA_BASE_URL=http://localhost:11434
